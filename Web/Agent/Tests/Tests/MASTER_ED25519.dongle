public 96;

/**
 *! INPUT[64] => Output[96] : || MASTER(0).ed25519.pubkey[32] | MASTER(0).ed25519.sign(SHA512(INPUT[64])) ||
 */

const {
    kOffsetMessage = 256;
    kOffsetSHA512  = 64;
    kOffsetSecret  = 192;    /// Header_sign_or_zero_ ...
}

rLANG_INPUT_MESSAGE @ kOffsetMessage [64];

@ 0  [32] : rLANG_Ed25519_Pubkey;
@ 32 [64] : rLANG_Ed25519_Signature;

///
/// 强制使用签名的前4个字节作为Type, 如果需要做类型0的签名, 可能需要使用SM2ECDSA签名的方式做POW产生前四个字节为0的签名.
///
ExDigestSHA512(kOffsetMessage, 64, kOffsetSHA512);
ComputeSecretBytes(kOffsetSecret, LoadI32(kOffsetSecret));
ExEd25519ComputePubkey(kOffsetSecret, 0);
ExEd25519Sign(0, kOffsetSecret, kOffsetSHA512, 64, 32);
Memset(96, 0, 1024 - 96);
