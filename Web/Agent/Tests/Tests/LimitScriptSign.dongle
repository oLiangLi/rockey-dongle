public 200;

const {
    kOffset_Sign = 200 - 64;
    kOffset_Input = 256;
    i = 512;
}

rLANG_SCRIPT_CODE @ kOffset_Input [200];

Memcpy(0, kOffset_Input, 200);

StoreI32(i, 200 - 64);
while(LoadI32(i) < 200) {
    if(0 != LoadU8(LoadI32(i)))
        Exit(LoadI32(i));
    StoreI32(i, LoadI32(i) + 1);
}

DigestSM3(0, kOffset_Sign, kOffset_Sign);
SM2Sign(4, kOffset_Sign, kOffset_Sign);
