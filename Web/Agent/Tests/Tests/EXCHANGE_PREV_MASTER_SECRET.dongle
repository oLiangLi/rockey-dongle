public 256;

const {
    kOff_X25519_K0 = 256;
    kOff_X25519_K1 = kOff_X25519_K0 + 32;
    kOff_X25519_K2 = kOff_X25519_K1 + 32;
    kOff_X25519_K3 = kOff_X25519_K2 + 32;
    kOff_IMPORT_RSA = kOff_X25519_K3 + 32;
}

@ 0 [256] : rLANG_ENCRYPT_PREV_MASTER_SECRET;

rLANG_X25519_PUBKEY_0 @ kOff_X25519_K0 [32];
rLANG_X25519_PUBKEY_1 @ kOff_X25519_K1 [32];
rLANG_X25519_PUBKEY_2 @ kOff_X25519_K2 [32];
rLANG_X25519_PUBKEY_3 @ kOff_X25519_K3 [32];
rLANG_RSA_PUBKEY @ kOff_IMPORT_RSA [260];

/**
 *! K0: A B C
 *! K1: A D E
 *! K2: B D F
 *! K3: C E F
 */
ExecuteExchangeMasterSecret();
Exit(42);
