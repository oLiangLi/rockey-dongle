public 104;

const {
    kOffsetDonglePublic = 7 * 1024;
    kOffsetPubkey_RSA2048 = 148;

    kOffset_PREV_MASTER_SECRET_0 = 256;
    kOffset_PREV_MASTER_SECRET_1 = kOffset_PREV_MASTER_SECRET_0 + 256;
    kOffset_PREV_MASTER_SECRET_2 = kOffset_PREV_MASTER_SECRET_1 + 256;
}

@ (0 * 16) [16] : rLANG_DONGLE_ID_0;
@ (1 * 16) [16] : rLANG_DONGLE_ID_1;
@ (2 * 16) [16] : rLANG_DONGLE_ID_2;
@ (3 * 16) [16] : rLANG_DONGLE_ID_3;
@ (4 * 16) [16] : rLANG_DONGLE_ID_4;
@ (5 * 16) [16] : rLANG_DONGLE_ID_5;
@ (6 * 16) [8] : rLANG_MASTER_SECRET_FINGERPRINT;

ReadDataFile(0xffff, kOffsetDonglePublic + kOffsetPubkey_RSA2048, 0, 260);

Memset(kOffset_PREV_MASTER_SECRET_1 + 0 * 48, 0, 48);
Memset(kOffset_PREV_MASTER_SECRET_1 + 1 * 48, 1, 48);
Memset(kOffset_PREV_MASTER_SECRET_1 + 2 * 48, 2, 48);
Memset(kOffset_PREV_MASTER_SECRET_1 + 3 * 48, 3, 48);
Memset(kOffset_PREV_MASTER_SECRET_1 + 4 * 48, 4, 48);
ExRSAPublicEncrypt(0, kOffset_PREV_MASTER_SECRET_1, 48 * 5);

Memset(kOffset_PREV_MASTER_SECRET_2 + 0 * 48, 1, 48);
Memset(kOffset_PREV_MASTER_SECRET_2 + 1 * 48, 2, 48);
Memset(kOffset_PREV_MASTER_SECRET_2 + 2 * 48, 3, 48);
Memset(kOffset_PREV_MASTER_SECRET_2 + 3 * 48, 4, 48);
Memset(kOffset_PREV_MASTER_SECRET_2 + 4 * 48, 5, 48);
ExRSAPublicEncrypt(0, kOffset_PREV_MASTER_SECRET_2, 48 * 5);

Memcpy(kOffset_PREV_MASTER_SECRET_0, kOffset_PREV_MASTER_SECRET_1, 256);

ExecuteImportMasterSecret();
Exit(42);

