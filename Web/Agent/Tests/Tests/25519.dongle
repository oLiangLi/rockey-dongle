public 1024;

const {
    kOff_Ed25519_public = 0;
    kOff__X25519_public1 = kOff_Ed25519_public  + 32;
    kOff__X25519_public2 = kOff__X25519_public1 + 32;

    kOff_Ed25519_pkey  = 128;
    kOff__X25519_pkey1 = kOff_Ed25519_pkey  + 32;
    kOff__X25519_pkey2 = kOff__X25519_pkey1 + 32;

    kOff_SHA256 = 0x200;
    kOff_SHA384 = 0x240;
    kOff_SHA512 = 0x280;

    kOff_Secret_1 = 1024 - 128;
    kOff_Secret_2 = kOff_Secret_1 + 32;
    kOff_Sign = kOff_Secret_2 + 32;
}

RandBytes(kOff_Ed25519_pkey,  32);
RandBytes(kOff__X25519_pkey1, 32);
RandBytes(kOff__X25519_pkey2, 32);

ExEd25519ComputePubkey(kOff_Ed25519_pkey, kOff_Ed25519_public);
ExCurve25519ComputePubkey(kOff__X25519_pkey1, kOff__X25519_public1);
ExCurve25519ComputePubkey(kOff__X25519_pkey2, kOff__X25519_public2);

ExCurve25519ComputeSecret(kOff__X25519_pkey1, kOff__X25519_public2, kOff_Secret_1);
ExCurve25519ComputeSecret(kOff__X25519_pkey2, kOff__X25519_public1, kOff_Secret_2);

ExDigestSHA256(0, kOff_SHA256, kOff_SHA256);
ExDigestSHA384(0, kOff_SHA384, kOff_SHA384);
ExDigestSHA512(0, kOff_SHA512, kOff_SHA512);

ExDigestSHA512(0, kOff_Sign, kOff_Sign);
ExEd25519Sign(kOff_Ed25519_public, kOff_Ed25519_pkey, kOff_Sign, 64, kOff_Sign);
